<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Drive Your Way</title>
    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
        }

        /* Back Arrow */
        .back-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background-color: black;
            color: white;
            padding: 8px 15px;
            border-radius: 5px;
            text-decoration: none;
            font-size: 16px;
            margin: 15px;
            transition: background-color 0.2s ease;
        }
        .back-btn:hover {
            background-color: gray;
        }

        /* Hero Section */
        .hero {
            background-color: orchid;
            color: white;
            padding: 40px 20px;
        }

        .container {
            display: flex;
            max-width: 1200px;
            margin: auto;
            align-items: center;
            gap: 20px;
            flex-wrap: wrap;
        }

        .left-column, .right-column {
            flex: 1;
            min-width: 300px;
        }

        .left-column h1 {
            font-size: 36px;
            font-weight: bold;
            margin: 0;
        }

        .left-column h2 {
            font-size: 18px;
            margin: 10px 0;
        }

        .button {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 20px;
            border-radius: 5px;
            margin: 5px 5px 5px 0;
            text-decoration: none;
            cursor: pointer;
            font-size: 16px;
        }

        .get-started {
            background-color: lavender;
            color: black;
        }

        .sign-in {
            color: white;
            text-decoration: underline;
        }

        .illustration {
            width: 100%;
            max-width: 400px;
        }

        /* Footer */
        .footer {
            background-color: lavender;
            padding: 40px;
            display: flex;
            flex-wrap: wrap;
        }

        .footer-column {
            flex: 1;
            min-width: 150px;
            margin: 10px;
        }

        .footer h5 {
            color: black;
            margin-bottom: 10px;
        }

        .footer a {
            color: black;
            text-decoration: none;
            display: block;
            margin: 5px 0;
        }

        .footer a:hover {
            text-decoration: underline;
        }

        .sign-up {
            background-color: lavender;
            text-align: center;
            padding: 20px;
        }

        .sign-up p {
            color: black;
            margin: 0;
        }

        .sign-up button {
            padding: 10px 20px;
            background-color: black;
            color: white;
            border: none;
            cursor: pointer;
            margin-top: 10px;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            font-size: 16px;
        }

        .sign-up button:hover {
            background-color: gray;
        }

        /* Extra Footer Styling */
        .footer-extra {
            background-color: lavender;
            text-align: center;
            padding: 20px;
            border-top: 1px solid #ccc;
        }

        .social-icons {
            margin-bottom: 15px;
        }

        .social-icons a {
            color: black;
            font-size: 24px;
            margin: 0 10px;
            transition: transform 0.2s ease, color 0.2s ease;
        }

        .social-icons a:hover {
            transform: scale(1.2);
            color: darkblue;
        }

        .app-buttons {
            margin-bottom: 15px;
        }

        .app-btn {
            display: inline-block;
            background-color: black;
            color: white;
            padding: 8px 15px;
            border-radius: 5px;
            margin: 0 5px;
            text-decoration: none;
            font-size: 14px;
            transition: background-color 0.2s ease;
        }

        .app-btn i {
            margin-right: 8px;
        }

        .app-btn:hover {
            background-color: gray;
        }

        .footer-bottom {
            font-size: 14px;
            color: black;
        }

        .footer-bottom a {
            color: black;
            text-decoration: none;
            margin: 0 8px;
        }

        .footer-bottom a:hover {
            text-decoration: underline;
        }

        /* Responsive Design */
        @media (max-width: 600px) {
            .footer {
                flex-direction: column;
            }
            .social-icons a {
                font-size: 20px;
            }
            .app-btn {
                font-size: 12px;
                padding: 6px 10px;
            }
        }
    </style>
</head>
<body>

    <!-- Back Button -->
    <a href="/default" class="back-btn">
        <i class="fas fa-arrow-left"></i> Back
    </a>

    <!-- Hero Section -->
    <div class="hero">
        <div class="container">
            <div class="left-column">
                <h1>Drive your way, live your freedom</h1>
                <h2>Join the ride-hailing revolution today.</h2>
                <a href="#" class="button get-started">
                    Get started <i class="fas fa-arrow-right"></i>
                </a>
                <a href="/login" class="button sign-in">Already have an account? Sign in</a>
            </div>
            <div class="right-column">
                <img src="/Images/shakti.png" alt="Minimal flat vector illustration of a woman driving a car" class="illustration">
            </div>
        </div>
    </div>

     <!-- Font Awesome CDN -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<footer class="footer">
    <div class="footer-column">
            <h5>Company</h5>
            <a href="/about">About</a>
            <a href="/safety">Safety</a>
            <a href="/career">Careers</a>
            <a href="/Help">Help</a>
        </div>
        <div class="footer-column">
            <h5>Products</h5>
            <a href="/ride">Ride</a>
            <a href="/drive">Drive</a>
        </div>
        <div class="footer-column">
            <h5>Global citizenship</h5>
            <a href="/sustainbility">Sustainability</a>
            <a href="/diversity">Diversity and Inclusion</a>
        </div>
</footer>

<div class="sign-up">
    <p>Sign up to drive</p>
    <button onclick="window.location.href='/driver-signup'">Get Started</button>
</div>

<div class="footer-extra">
    <div class="social-icons">
        <a href="#"><i class="fab fa-facebook"></i></a>
        <a href="#"><i class="fab fa-twitter"></i></a>
        <a href="#"><i class="fab fa-instagram"></i></a>
        <a href="#"><i class="fab fa-linkedin"></i></a>
    </div>

    <div class="app-buttons" style="margin-top: 10px;">
        <!-- Google Play Button -->
        <a href="https://play.google.com/store" target="_blank" class="app-btn" 
        style="display: inline-block; margin: 5px; padding: 10px 15px; background-color: black; color: white; border-radius: 5px; text-decoration: none;">
            <i class="fab fa-google-play"></i> Google Play
        </a>

        <!-- App Store Button -->
        <a href="https://www.apple.com/in/app-store/" target="_blank" class="app-btn" 
        style="display: inline-block; margin: 5px; padding: 10px 15px; background-color: black; color: white; border-radius: 5px; text-decoration: none;">
            <i class="fab fa-apple"></i> App Store
        </a>
    </div>

    <div class="footer-bottom">
        <span>© 2025 ShaktiRide</span>
         <a href="/privacy">Privacy</a>|
        <a href="/accessibility">Accessibility</a>|
        <a href="/terms">Terms</a>
    </div>
</div>


</body>
</html>
