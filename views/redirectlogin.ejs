<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>ShaktiRide - Driven by Safety, Powered by Care</title>
<!-- Font Awesome for icons -->
  <link
    rel="stylesheet"
    href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"
  />
<script src="https://cdn.tailwindcss.com"></script>
<style>
    @import url('https://fonts.googleapis.com/css2?family=Uber+Move:wght@400;700&display=swap');
    body {
        font-family: 'UberMove', sans-serif;
        background-color: white;
        color: #000;
    }
    .input-with-icon {
        position: relative;
    }
    .input-with-icon button {
        position: absolute;
        right: 0.75rem;
        top: 50%;
        transform: translateY(-50%);
        background: transparent;
        border: none;
        cursor: pointer;
        padding: 0.15rem;
        color: black;
        transition: color 0.2s ease;
    }
    .input-with-icon button:hover {
        color: black;
    }
</style>
</head>
<body class="overflow-x-hidden">

<!-- Navigation -->
<nav class="sticky top-0 bg-purple-200 shadow flex justify-between items-center px-4 py-3 z-50">
    <div class="flex items-center space-x-6">
        <h1 class="text-xl font-bold cursor-pointer" onclick="window.location.href='index.html'">ShaktiRide</h1>
        <ul class="hidden md:flex space-x-4">
            <li><a href="#"><i class="fa-solid fa-car"></i> Ride</a></li>
            <li><a href="#"><i class="fa-solid fa-clock"></i> Rentals</a></li>
        </ul>
    </div>
    <div class="flex items-center space-x-4">
        <a href="#"><i class="fa-solid fa-list"></i> Activity</a>
        <button class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded">Profile</button>
    </div>
</nav>

<!-- Main Section -->
<main>
<section class="main-section flex flex-col md:flex-row justify-center items-center gap-10 px-4 py-10 max-w-6xl mx-auto">

    <!-- Form -->
    <div class="form-container w-full md:w-1/2 bg-white p-6 rounded-xl shadow-lg">
        <h2 class="text-3xl font-bold mb-6">Book Your Ride</h2>
        <form id="rideBookingForm" class="space-y-5">

            <!-- Pickup -->
            <div class="input-with-icon">
                <label for="pickupLocation" class="font-semibold">Pickup Location</label>
                <input type="text" id="pickupLocation" name="pickupLocation" placeholder="Enter pickup location"
                    class="w-full border border-blue-400 rounded-lg p-3 bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500" />
                <button type="button" id="getLocationBtn" aria-label="Get exact pickup location">
                    📍
                </button>
            </div>

            <!-- Dropoff -->
            <div class="input-with-icon">
                <label for="dropoffLocation" class="font-semibold">Dropoff Location</label>
                <input type="text" id="dropoffLocation" name="dropoffLocation" placeholder="Enter dropoff location"
                    class="w-full border border-blue-400 rounded-lg p-3 bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500" />
                <button type="button" onclick="openGoogleMaps()" aria-label="Choose dropoff on map">
                    🗺
                </button>
            </div>

            <!-- Date & Time -->
            <div class="flex gap-4">
                <div class="w-1/2">
                    <label for="rideDate" class="font-semibold">Date</label>
                    <input type="date" id="rideDate" name="rideDate"
                        class="w-full border border-blue-400 rounded-lg p-3 bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500" />
                </div>
                <div class="w-1/2">
                    <label for="rideTime" class="font-semibold">Time</label>
                    <input type="time" id="rideTime" name="rideTime"
                        class="w-full border border-blue-400 rounded-lg p-3 bg-gray-50 focus:outline-none focus:ring-2 focus:ring-blue-500" />
                </div>
            </div>

            <!-- Submit -->
            <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white w-full py-3 rounded-lg text-lg font-semibold">Submit</button>
        </form>
    </div>

    <!-- Map -->
    <div class="w-full md:w-1/2">
        <iframe src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d114312.51528006422!2d80.25598108854274!3d26.447150071654423!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x399c4770b127c46f%3A0x1778302a9fbe7b41!2sKanpur%2C%20Uttar%20Pradesh!5e0!3m2!1sen!2sin!4v1754754331615!5m2!1sen!2sin"
            width="100%" height="400" class="rounded-xl shadow-lg" loading="lazy"></iframe>
    </div>

</section>
</main>

<!-- Script -->
<script>
    const dateInput = document.getElementById('rideDate');
    const timeInput = document.getElementById('rideTime');
    function pad(num) { return num < 10 ? '0' + num : num; }
    function setDefaultDateTime() {
        const now = new Date();
        dateInput.value = now.toISOString().split('T')[0];
        let minutes = now.getMinutes();
        minutes = Math.ceil(minutes / 10) * 10;
        if (minutes === 60) {
            now.setHours(now.getHours() + 1);
            minutes = 0;
        }
        timeInput.value = pad(now.getHours()) + ':' + pad(minutes);
    }
    setDefaultDateTime();

    const getLocationBtn = document.getElementById('getLocationBtn');
    const pickupInput = document.getElementById('pickupLocation');
    getLocationBtn.addEventListener('click', () => {
        if (!navigator.geolocation) {
            alert('Geolocation is not supported by your browser.');
            return;
        }
        navigator.geolocation.getCurrentPosition(
            (position) => {
                const { latitude, longitude } = position.coords;
                pickupInput.value = `Lat: ${latitude.toFixed(4)}, Lon: ${longitude.toFixed(4)}`;
            },
            () => alert('Unable to retrieve your location. Please enter it manually.'),
            { enableHighAccuracy: true, timeout: 10000, maximumAge: 0 }
        );
    });

    function openGoogleMaps() {
        window.open("https://www.google.com/maps", "_blank");
    }

    document.getElementById('rideBookingForm').addEventListener('submit', (e) => {
        e.preventDefault();
        const pickup = pickupInput.value.trim();
        const dropoff = document.getElementById('dropoffLocation').value.trim();
        const date = dateInput.value;
        const time = timeInput.value;
        if (!pickup || !dropoff || !date || !time) {
            alert('Please fill in all fields before checking prices.');
            return;
        }
        alert(`Checking prices for ride:\nPickup: ${pickup}\nDropoff: ${dropoff}\nOn ${date} at ${time}`);
    });
</script>

</body>
</html>