<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>About Us - ShaktiRide</title>
    <!-- Font Awesome CDN -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
    body {
    font-family: 'Arial', sans-serif;
    margin: 0;
    padding: 20px;
    background: plum; /* light purple */
    color: black;
}

.about-section {
    display: flex;
    flex-direction: row;
    padding: 50px 0;
    align-items: center;
    background: #ac82d8;
}

.content {
    display: flex;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
}

/* Left Column Styling */
.left-column {
    flex: 1;
    padding: 20px;
    color: black;
    max-width: 550px;
}

.left-column h1 {
    font-weight: bold;
    font-size: 2.5em;
    margin-bottom: 0.2em;
    color: #6A0DAD; /* deep purple */
}

.left-column h2 {
    font-weight: 600;
    margin-top: 20px;
    color: #8E44AD;
}

.left-column h3 {
    font-weight: bold;
    margin-top: 20px;
}

.left-column p {
    margin-top: 10px;
    line-height: 1.6;
}

/* CTA Button */
.cta-button {
    display: inline-block;
    padding: 12px 24px;
    background: #6A0DAD;
    color: white;
    font-size: 1.1em;
    border-radius: 30px;
    margin-top: 20px;
    text-decoration: none;
    transition: background 0.3s ease;
}

.cta-button:hover {
    background: #5B0BA3;
}

/* Right Column Styling */
.right-column {
    flex: 1;
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;
}


/* Rapido-style image frame */
.image-frame {
    position: relative;
    display: inline-block;
}

.bg-image {
    width: 500px; /* Pehle 400px thi, ab aur badi */
    height: auto;
    border-radius: 20px;
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.2);
}

.circle-image {
    position: absolute;
    bottom: -35px;
    right: -35px;
    width: 220px; /* Pehle 180px thi */
    height: 220px;
    border-radius: 50%;
    border: 8px solid white;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
    background: white;
}

/* Gradient Background Circle size update */
.right-column::before {
    content: "";
    position: absolute;
    top: 10%;
    left: 10%;
    width: 380px; /* Pehle 300px thi */
    height: 380px;
    background: radial-gradient(circle, #DCC6E0 0%, transparent 70%);
    border-radius: 50%;
    z-index: -1;
}




/* Hover Effect */
.bg-image:hover,
.circle-image:hover {
    transform: scale(1.05);
    transition: transform 0.3s ease;
}

/* Responsive */
@media (max-width: 768px) {
    .about-section {
        flex-direction: column;
    }

    .left-column, 
    .right-column {
        width: 100%;
        position: static;
        margin-bottom: 20px;
        text-align: center;
    }

    .bg-image {
        width: 90%;
    }

    .circle-image {
        position: relative;
        bottom: auto;
        right: auto;
        margin-top: 15px;
    }

    .right-column::before {
        display: none;
    }
}


    /* Footer */
body {
    margin: 0;
    font-family: Arial, sans-serif;
}

.footer {
    background-color: lavender;
    padding: 40px;
    display: flex;
    flex-wrap: wrap;
}

.footer-column {
    flex: 1;
    min-width: 150px;
    margin: 10px;
}

.footer h5 {
    color: black;
    margin-bottom: 10px;
}

.footer a {
    color: black;
    text-decoration: none;
    display: block;
    margin: 5px 0;
}

.footer a:hover {
    text-decoration: underline;
}

.sign-up {
    background-color: lavender;
    text-align: center;
    padding: 20px;
}

.sign-up p {
    color: black;
    margin: 0;
}

.sign-up button {
    padding: 10px 20px;
    background-color: black;
    color: white;
    border: none;
    cursor: pointer;
    margin-top: 10px;
}

.sign-up button:hover {
    background-color: gray;
}

/* Extra Footer Styling */
.footer-extra {
    background-color: lavender;
    text-align: center;
    padding: 20px;
    border-top: 1px solid #ccc;
}

.social-icons {
    margin-bottom: 15px;
}

.social-icons a {
    color: black;
    font-size: 24px;
    margin: 0 10px;
    transition: transform 0.2s ease, color 0.2s ease;
}

.social-icons a:hover {
    transform: scale(1.2);
    color: darkblue;
}

.app-buttons {
    margin-bottom: 15px;
}

.app-btn {
    display: inline-block;
    background-color: black;
    color: white;
    padding: 8px 15px;
    border-radius: 5px;
    margin: 0 5px;
    text-decoration: none;
    font-size: 14px;
    transition: background-color 0.2s ease;
}

.app-btn i {
    margin-right: 8px;
}

.app-btn:hover {
    background-color: gray;
}

.footer-bottom {
    font-size: 14px;
    color: black;
}

.footer-bottom a {
    color: black;
    text-decoration: none;
    margin: 0 8px;
}

.footer-bottom a:hover {
    text-decoration: underline;
}

/* Responsive Design */
@media (max-width: 600px) {
    .footer {
        flex-direction: column;
    }
    .social-icons a {
        font-size: 20px;
    }
    .app-btn {
        font-size: 12px;
        padding: 6px 10px;
    }
}


.back-btn {
    position: fixed;
    top: 20px;
    left: 20px;
    font-size: 24px;
    color: black;
    background: white;
    padding: 8px 10px;
    border-radius: 50%;
    text-decoration: none;
    box-shadow: 0 2px 6px rgba(0,0,0,0.2);
    transition: background 0.3s ease, transform 0.2s ease;
    z-index: 999;
}
.back-btn:hover {
    background: #f0f0f0;
    transform: scale(1.1);
}

    </style>
</head>
<body>
    <!-- Back Button -->
    <a href="index.html" class="back-btn">
