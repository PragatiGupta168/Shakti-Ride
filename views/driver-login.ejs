<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Driver Login - ShaktiRide</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: lavender; /* Tumhara bg color */
            margin: 0;
            padding: 0;
        }

        .container {
            width: 100%;
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .login-box {
            background-color: white;
            padding: 25px;
            border-radius: 10px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.2);
            width: 350px;
            text-align: center;
        }

        .login-box h2 {
            margin-bottom: 20px;
            color: #333;
        }

        .login-box input[type="text"],
        .login-box input[type="password"] {
            width: 100%;
            padding: 10px;
            margin: 8px 0;
            border: 1px solid #ccc;
            border-radius: 5px;
        }

        .login-box button {
            width: 100%;
            padding: 10px;
            background-color: purple;
            color: white;
            border: none;
            border-radius: 5px;
            font-size: 16px;
            cursor: pointer;
            transition: 0.3s;
        }

        .login-box button:hover {
            background-color: darkmagenta;
        }

        .login-box p {
            margin-top: 15px;
            font-size: 14px;
        }

        .login-box a {
            color: purple;
            text-decoration: none;
        }

        .login-box a:hover {
            text-decoration: underline;
        }

         /* Footer */

    body {
    margin: 0;
    font-family: Arial, sans-serif;
}

.footer {
    background-color: lavender;
    padding: 40px;
    display: flex;
    flex-wrap: wrap;
}

.footer-column {
    flex: 1;
    min-width: 150px;
    margin: 10px;
}

.footer h5 {
    color: black;
    margin-bottom: 10px;
}

.footer a {
    color: black;
    text-decoration: none;
    display: block;
    margin: 5px 0;
}

.footer a:hover {
    text-decoration: underline;
}

.sign-up {
    background-color: lavender;
    text-align: center;
    padding: 20px;
}

.sign-up p {
    color: black;
    margin: 0;
}

.sign-up button {
    padding: 10px 20px;
    background-color: black;
    color: white;
    border: none;
    cursor: pointer;
    margin-top: 10px;
}

.sign-up button:hover {
    background-color: gray;
}

/* Extra Footer Styling */
.footer-extra {
    background-color: lavender;
    text-align: center;
    padding: 20px;
    border-top: 1px solid #ccc;
}

.social-icons {
    margin-bottom: 15px;
}

.social-icons a {
    color: black;
    font-size: 24px;
    margin: 0 10px;
    transition: transform 0.2s ease, color 0.2s ease;
}

.social-icons a:hover {
    transform: scale(1.2);
    color: darkblue;
}

.app-buttons {
    margin-bottom: 15px;
}

.app-btn {
    display: inline-block;
    background-color: black;
    color: white;
    padding: 8px 15px;
    border-radius: 5px;
    margin: 0 5px;
    text-decoration: none;
    font-size: 14px;
    transition: background-color 0.2s ease;
}

.app-btn i {
    margin-right: 8px;
}

.app-btn:hover {
    background-color: gray;
}

.footer-bottom {
    font-size: 14px;
    color: black;
}

.footer-bottom a {
    color: black;
    text-decoration: none;
    margin: 0 8px;
}

.footer-bottom a:hover {
    text-decoration: underline;
}

    </style>
</head>
<body>

    <div class="container">
        <div class="login-box">
            <h2>Driver Login</h2>
            <form action="#" method="post">
                <input type="text" name="username" placeholder="Username" required>
                <input type="password" name="password" placeholder="Password" required>
                <button type="submit">Login</button>
            </form>
            <p>Don't have an account? <a href="/driver-signup">Sign up here</a></p>
        </div>
    </div>

    <!-- Font Awesome CDN -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<footer class="footer">
<div class="footer-column">
            <h5>Company</h5>
            <a href="/about">About</a>
            <a href="/safety">Safety</a>
            <a href="/career">Careers</a>
            <a href="/help">Help</a>
        </div>
        <div class="footer-column">
            <h5>Products</h5>
            <a href="/ride">Ride</a>
            <a href="/drive">Drive</a>
        </div>
        <div class="footer-column">
            <h5>Global citizenship</h5>
            <a href="/sustainbility">Sustainability</a>
            <a href="/diversity">Diversity and Inclusion</a>
        </div>
</footer>

<div class="sign-up">
    <p>Sign up to drive</p>
    <button onclick="window.location.href='/driver-signup'">Get Started</button>
</div>

<div class="footer-extra">
    <div class="social-icons">
        <a href="#"><i class="fab fa-facebook"></i></a>
        <a href="#"><i class="fab fa-twitter"></i></a>
        <a href="#"><i class="fab fa-instagram"></i></a>
        <a href="#"><i class="fab fa-linkedin"></i></a>
    </div>

    <div class="app-buttons" style="margin-top: 10px;">
        <!-- Google Play Button -->
        <a href="https://play.google.com/store" target="_blank" class="app-btn" 
        style="display: inline-block; margin: 5px; padding: 10px 15px; background-color: black; color: white; border-radius: 5px; text-decoration: none;">
            <i class="fab fa-google-play"></i> Google Play
        </a>

        <!-- App Store Button -->
        <a href="https://www.apple.com/in/app-store/" target="_blank" class="app-btn" 
        style="display: inline-block; margin: 5px; padding: 10px 15px; background-color: black; color: white; border-radius: 5px; text-decoration: none;">
            <i class="fab fa-apple"></i> App Store
        </a>
    </div>

    <div class="footer-bottom">
        <span>© 2025 ShaktiRide</span>
         <a href="/privacy">Privacy</a>|
        <a href="/accessibility">Accessibility</a>|
        <a href="/terms">Terms</a>
    </div>
</div>

</body>
</html>
