    padding: 20px;
    border-radius: 8px;
  }
  section h2 {
    color: #ffe082;
    margin-bottom: 10px;
  }
  section p {
    margin: 0;
  }
  /* Footer */

    body {
    margin: 0;
    font-family: Arial, sans-serif;
}

.footer {
    background-color: lavender;
    padding: 40px;
    display: flex;
    flex-wrap: wrap;
}

.footer-column {
    flex: 1;
    min-width: 150px;
    margin: 10px;
}

.footer h5 {
    color: black;
    margin-bottom: 10px;
}

.footer a {
    color: black;
    text-decoration: none;
    display: block;
    margin: 5px 0;
}

.footer a:hover {
    text-decoration: underline;
}

.sign-up {
    background-color: lavender;
    text-align: center;
    padding: 20px;
}

.sign-up p {
    color: black;
    margin: 0;
}

.sign-up button {
    padding: 10px 20px;
    background-color: black;
    color: white;
    border: none;
    cursor: pointer;
    margin-top: 10px;
}

.sign-up button:hover {
    background-color: gray;
}

/* Extra Footer Styling */
.footer-extra {
    background-color: lavender;
    text-align: center;
    padding: 20px;
    border-top: 1px solid #ccc;
}

.social-icons {
    margin-bottom: 15px;
}

.social-icons a {
    color: black;
    font-size: 24px;
    margin: 0 10px;
    transition: transform 0.2s ease, color 0.2s ease;
}

.social-icons a:hover {
    transform: scale(1.2);
    color: darkblue;
}

.app-buttons {
    margin-bottom: 15px;
}

.app-btn {
    display: inline-block;
    background-color: black;
    color: white;
    padding: 8px 15px;
    border-radius: 5px;
    margin: 0 5px;
    text-decoration: none;
    font-size: 14px;
    transition: background-color 0.2s ease;
}

.app-btn i {
    margin-right: 8px;
}

.app-btn:hover {
    background-color: gray;
}

.footer-bottom {
    font-size: 14px;
    color: black;
}

.footer-bottom a {
    color: black;
    text-decoration: none;
    margin: 0 8px;
}

.footer-bottom a:hover {
    text-decoration: underline;
}

/* Responsive Design */
@media (max-width: 600px) {
    .footer {
        flex-direction: column;
    }
    .social-icons a {
        font-size: 20px;
    }
    .app-btn {
        font-size: 12px;
        padding: 6px 10px;
    }
}
</style>
