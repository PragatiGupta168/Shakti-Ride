<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Careers - ShaktiRide</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: rgb(233, 168, 244);
            margin: 0;
            padding: 0;
        }
        header {
            background-color: white;
            padding: 15px;
            text-align: center;
            font-size: 24px;
            font-weight: bold;
        }
        main {
            max-width: 800px;
            margin: 20px auto;
            background: white;
            padding: 20px;
            border-radius: 10px;
        }
        h2 {
            color: #444;
        }
        .job {
            border-bottom: 1px solid #ddd;
            padding: 10px 0;
        }
        .apply-btn {
            background-color: rgb(233, 168, 244);
            border: none;
            padding: 10px 15px;
            cursor: pointer;
            border-radius: 5px;
            font-weight: bold;
        }

         /* Footer */

    body {
    margin: 0;
    font-family: Arial, sans-serif;
}

.footer {
    background-color: lavender;
    padding: 40px;
    display: flex;
    flex-wrap: wrap;
}

.footer-column {
    flex: 1;
    min-width: 150px;
    margin: 10px;
}

.footer h5 {
    color: black;
    margin-bottom: 10px;
}

.footer a {
    color: black;
    text-decoration: none;
    display: block;
    margin: 5px 0;
}

.footer a:hover {
    text-decoration: underline;
}

.sign-up {
    background-color: lavender;
    text-align: center;
    padding: 20px;
}

.sign-up p {
    color: black;
    margin: 0;
}

.sign-up button {
    padding: 10px 20px;
    background-color: black;
    color: white;
    border: none;
    cursor: pointer;
    margin-top: 10px;
}

.sign-up button:hover {
    background-color: gray;
}

/* Extra Footer Styling */
.footer-extra {
    background-color: lavender;
    text-align: center;
    padding: 20px;
    border-top: 1px solid #ccc;
}

.social-icons {
    margin-bottom: 15px;
}

.social-icons a {
    color: black;
    font-size: 24px;
    margin: 0 10px;
    transition: transform 0.2s ease, color 0.2s ease;
}

.social-icons a:hover {
    transform: scale(1.2);
    color: darkblue;
}

.app-buttons {
    margin-bottom: 15px;
}

.app-btn {
    display: inline-block;
    background-color: black;
    color: white;
    padding: 8px 15px;
    border-radius: 5px;
    margin: 0 5px;
    text-decoration: none;
    font-size: 14px;
    transition: background-color 0.2s ease;
}

.app-btn i {
    margin-right: 8px;
}

.app-btn:hover {
    background-color: gray;
}

.footer-bottom {
    font-size: 14px;
    color: black;
}

.footer-bottom a {
    color: black;
    text-decoration: none;
    margin: 0 8px;
}

.footer-bottom a:hover {
    text-decoration: underline;
}

    </style>
</head>
<body>
    <header>Join the ShaktiRide Team</header>
    <main>
        <h2>Why Work With Us?</h2>
        <p>ShaktiRide is not just a ride service — it’s a movement to empower women through safe transportation. Be a part of our growing family and make a difference.</p>
        
        <h3>Current Openings</h3>
        
        <div class="job">
            <h4>🚗 Women Driver Partner</h4>
            <p>Help women travel safely by becoming a driver partner. Flexible working hours and great earnings.</p>
            <button class="apply-btn">Apply Now</button>
        </div>

        <div class="job">
            <h4>📞 Customer Support Executive</h4>
            <p>Provide assistance to our riders and drivers with empathy and professionalism.</p>
            <button class="apply-btn">Apply Now</button>
        </div>

        <div class="job">
            <h4>💻 Marketing & Social Media Executive</h4>
            <p>Spread awareness about ShaktiRide through digital platforms.</p>
            <button class="apply-btn">Apply Now</button>
        </div>
    </main>

      <!-- Font Awesome CDN -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<footer class="footer">
    <div class="footer-column">
            <h5>Company</h5>
            <a href="/about">About</a>
            <a href="/safety">Safety</a>
            <a href="/career">Careers</a>
            <a href="/Help">Help</a>
        </div>
        <div class="footer-column">
            <h5>Products</h5>
            <a href="/ride">Ride</a>
            <a href="/drive">Drive</a>
        </div>
        <div class="footer-column">
            <h5>Global citizenship</h5>
            <a href="/sustainbility">Sustainability</a>
            <a href="/diversity">Diversity and Inclusion</a>
        </div>
</footer>

<div class="sign-up">
    <p>Sign up to drive</p>
    <button onclick="window.location.href='/driver-signup'">Get Started</button>
</div>

<div class="footer-extra">
    <div class="social-icons">
        <a href="#"><i class="fab fa-facebook"></i></a>
        <a href="#"><i class="fab fa-twitter"></i></a>
        <a href="#"><i class="fab fa-instagram"></i></a>
        <a href="#"><i class="fab fa-linkedin"></i></a>
    </div>

    <div class="app-buttons" style="margin-top: 10px;">
        <!-- Google Play Button -->
        <a href="https://play.google.com/store" target="_blank" class="app-btn" 
        style="display: inline-block; margin: 5px; padding: 10px 15px; background-color: black; color: white; border-radius: 5px; text-decoration: none;">
            <i class="fab fa-google-play"></i> Google Play
        </a>

        <!-- App Store Button -->
        <a href="https://www.apple.com/in/app-store/" target="_blank" class="app-btn" 
        style="display: inline-block; margin: 5px; padding: 10px 15px; background-color: black; color: white; border-radius: 5px; text-decoration: none;">
            <i class="fab fa-apple"></i> App Store
        </a>
    </div>

    <div class="footer-bottom">
        <span>© 2025 ShaktiRide</span>
         <a href="/privacy">Privacy</a>|
        <a href="/accessibility">Accessibility</a>|
        <a href="/terms">Terms</a>
    </div>
</div>

</body>
</html>
