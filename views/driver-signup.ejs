<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Driver Signup - ShaktiRide</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 0;
            padding: 0;
            background-color: rgb(233, 168, 244);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
        }

        .signup-container {
            background-color: white;
            padding: 30px;
            border-radius: 12px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
            width: 100%;
            max-width: 400px;
        }

        .signup-container h2 {
            text-align: center;
            color: #444;
            margin-bottom: 20px;
        }

        .signup-container label {
            font-weight: bold;
            display: block;
            margin-top: 10px;
            color: #333;
        }

        .signup-container input, 
        .signup-container select {
            width: 100%;
            padding: 10px;
            margin-top: 5px;
            border-radius: 6px;
            border: 1px solid #ccc;
            font-size: 14px;
            box-sizing: border-box;
        }

        .signup-container input:focus,
        .signup-container select:focus {
            outline: none;
            border-color: #a64ca6;
            box-shadow: 0 0 5px rgba(166, 76, 166, 0.5);
        }

        .signup-container button {
            background-color: #a64ca6;
            color: white;
            font-size: 16px;
            padding: 12px;
            border: none;
            border-radius: 6px;
            width: 100%;
            margin-top: 15px;
            cursor: pointer;
            transition: 0.3s;
        }

        .signup-container button:hover {
            background-color: #8c3d8c;
        }

        .signup-container p {
            text-align: center;
            margin-top: 15px;
            font-size: 14px;
        }

        .signup-container p a {
            color: #a64ca6;
            text-decoration: none;
        }

        .signup-container p a:hover {
            text-decoration: underline;
        }
    </style>
</head>
<body>

    <div class="signup-container">
        <h2>Driver Signup</h2>
        <form action="#" method="post">
            <label for="name">Full Name</label>
            <input type="text" id="name" name="name" placeholder="Enter your full name" required>

            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" placeholder="Enter your email" required>

            <label for="phone">Phone Number</label>
            <input type="tel" id="phone" name="phone" placeholder="Enter your phone number" required>

            <label for="vehicle">Vehicle Type</label>
            <select id="vehicle" name="vehicle" required>
                <option value="">-- Select Vehicle --</option>
                <option value="scooter">Scooter</option>
                <option value="bike">Bike</option>
                <option value="auto">Auto</option>
            </select>

            <label for="license">License Number</label>
            <input type="text" id="license" name="license" placeholder="Enter your license number" required>

            <label for="password">Create Password</label>
            <input type="password" id="password" name="password" placeholder="Enter password" required>

            <button type="submit">Sign Up</button>
        </form>
        <p>Already have an account? <a href="/driver-login">Login here</a></p>
    </div>

</body>
</html>
