<script>
    // Set default date & time to today and now + 10 mins for usability
    const dateInput = document.getElementById('rideDate');
    const timeInput = document.getElementById('rideTime');

    function pad(num) {
      return num < 10 ? '0' + num : num;
    }

    function setDefaultDateTime() {
      const now = new Date();
      dateInput.value = now.toISOString().split('T')[0];

      // Round time up to next 10 minutes
      let minutes = now.getMinutes();
      minutes = Math.ceil(minutes / 10) * 10;
      if (minutes === 60) {
        now.setHours(now.getHours() + 1);
        minutes = 0;
      }
      timeInput.value = pad(now.getHours()) + ':' + pad(minutes);
    }
    setDefaultDateTime();

    // Get exact location button functionality
    const getLocationBtn = document.getElementById('getLocationBtn');
    const pickupInput = document.getElementById('pickupLocation');

    getLocationBtn.addEventListener('click', () => {
      if (!navigator.geolocation) {
        alert('Geolocation is not supported by your browser.');
        return;
      }
      getLocationBtn.disabled = true;
      getLocationBtn.setAttribute('aria-busy', 'true');
      getLocationBtn.title = 'Getting your location...';

      navigator.geolocation.getCurrentPosition(
        (position) => {
          const { latitude, longitude } = position.coords;

          // Use a geocoding API to translate lat/lng to address (mock here with placeholder)
          // For demo, just fill coordinates text
          pickupInput.value = `Lat: ${latitude.toFixed(4)}, Lon: ${longitude.toFixed(4)}`;

        getLocationBtn.disabled = false;
        getLocationBtn.removeAttribute('aria-busy');
        getLocationBtn.title = 'Get exact pickup location';
        pickupInput.focus();
        },
        (error) => {
          alert('Unable to retrieve your location. Please enter it manually.');
          getLocationBtn.disabled = false;
          getLocationBtn.removeAttribute('aria-busy');
          getLocationBtn.title = 'Get exact pickup location';
        },
        {
          enableHighAccuracy: true,
          timeout: 10000,
          maximumAge: 0,
        }
      );
    });

    // Form submission (for demo only)
    const rideBookingForm = document.getElementById('rideBookingForm');
    rideBookingForm.addEventListener('submit', (e) => {
      e.preventDefault();
      const pickup = pickupInput.value.trim();
      const dropoff = rideBookingForm.dropoffLocation.value.trim();
      const date = dateInput.value;
      const time = timeInput.value;

      if (!pickup || !dropoff || !date || !time) {
        alert('Please fill in all fields before checking prices.');
        return;
      }

      alert(`Checking prices for ride:\nPickup: ${pickup}\nDropoff: ${dropoff}\nOn ${date} at ${time}`);
      // Booking logic and backend integration would go here for a MERN app
    });

    // Language Selector

// Get references to necessary elements
const langBtn = document.getElementById('lang-btn');
const popup = document.getElementById('popup');
const closeBtn = document.getElementById('close-btn');
const languageOptions = document.querySelectorAll('.language-option');

// Function to show the popup
langBtn.addEventListener('click', (event) => {
    popup.classList.toggle('hidden');
});

// Function to hide the popup
closeBtn.addEventListener('click', () => {
    popup.classList.add('hidden');
});

languageOptions.forEach(option => {
    option.addEventListener('click', (event) => {
        const selectedLang = event.target.getAttribute('data-lang');
        langBtn.textContent = selectedLang; // Update the navbar text
        popup.classList.add('hidden'); // Hide the popup after selection
    });
});

// Hide popup when clicking outside of it
window.addEventListener('click', (event) => {
    if (!popup.contains(event.target) && event.target !== langBtn) {
        popup.classList.add('hidden');
    }
});


// Scrolling

 document.addEventListener("DOMContentLoaded", function() {
      const scrollTopBtn = document.getElementById("scrollTopBtn");

      window.addEventListener("scroll", () => {
        if (window.scrollY > 100) {
          scrollTopBtn.style.display = "flex";
        } else {
          scrollTopBtn.style.display = "none";
        }
      });

      scrollTopBtn.addEventListener("click", () => {
        window.scrollTo({ top: 0, behavior: "smooth" });
      });

      scrollTopBtn.addEventListener("touchstart", () => {
        window.scrollTo({ top: 0, behavior: "smooth" });
      });
    });

    //Signup
    function toggleDropdown() {
        let menu = document.getElementById("dropdownMenu");
        menu.style.display = (menu.style.display === "block") ? "none" : "block";
    }

    // Outside click pe close ho
    window.addEventListener("click", function(event) {
        if (!event.target.closest("nav")) {
            document.getElementById("dropdownMenu").style.display = "none";
        }
    });

</script>


