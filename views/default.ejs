    /* Rounded inputs and buttons with subtle shadows */
    input, select, button {
    border-radius: 0.75rem;
    box-shadow: 0 1.5px 4px rgb(0 0 0 / 0.1);
    transition: box-shadow 0.2s ease, border-color 0.2s ease;
    }
    input:focus, select:focus {
    outline: none;
    border-color: #2563eb; /* bright blue */
    box-shadow: 0 0 4px #3b82f6;
    background-color: #f9fafb;
    }
    button {
    background-color: #2563eb;
    color: white;
    font-weight: 700;
    border: none;
    cursor: pointer;
    }
    button:hover, button:focus {
    background-color: #1e40af;
    box-shadow: 0 0 8px #3b82f6;
    }

   /* Navigation bar style */
nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    background-color: rgb(69, 69, 184);
    padding: 10px;
    box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
}


nav h1 {
    margin: 0;
    color: black;
    font-weight: bold; /* Bold karega */
    font-size: 1.5rem; /* Size bada karega */
}

nav ul {
    list-style-type: none;
    display: flex;
    margin: 0;
    padding: 0;
}

nav li {
    margin: 0 15px;
    color: black;
}

nav button {
    border: none;
    background-color: blue;
    color: white;
    border-radius: 5px;
    padding: 10px 15px;
    margin: 0 5px;
}

/* Mobile view */
@media (max-width: 768px) {
    nav {
        flex-direction: column;
        align-items: flex-start;
    }

    nav ul {
        flex-direction: column;
        margin-top: 10px;
    }

    nav li {
        margin: 5px 0;
    }
}

    
    /* Main container */
    .main-section {
    display: flex;
    flex-direction: row;
    justify-content: center;
    align-items: center;
    gap: 3rem;
    padding: 3rem 2rem 5rem 2rem;
    max-width: 1200px;
    margin: 0 auto;
    }
    /* Responsive stack on smaller screens */
    @media (max-width: 768px) {
    .main-section {
        flex-direction: column;
        padding: 2rem 1rem 3rem 1rem;
        gap: 2rem;
    }
    }

    /* Left side form container */
    .form-container {
flex: 1 1 400px;
max-width: 500px;
    }
    .headline {
    font-weight: 900;
    font-size: 2.75rem;
    line-height: 1.15;
    margin-bottom: 1.5rem;
      /* user-select: none; */
    color: #000000;
    }
    @media (max-width: 768px) {
    .headline {
        font-size: 2.125rem;
        text-align: center;
    }
    }

    /* Form styles */
    form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    }
    label {
    font-weight: 600;
    margin-bottom: 0.5rem;
    display: block;
    color: #111111;
      /* user-select: none; */
    }
    input[type="text"], input[type="date"], input[type="time"] {
    width: 100%;
    padding: 0.8rem 1rem;
    border: 1px solid #5d93e5;
    font-size: 1rem;
    color: #111827;
    background: #f9fafb;
    -webkit-appearance: none;
    -moz-appearance: none;
    appearance: none;
    }
    .input-group-horizontal {
    display: flex;
    gap: 1rem;
    }
    .input-group-horizontal > div {
    flex: 1 1 50%;
    }
    .input-with-icon {
    position: relative;
    }
    .input-with-icon button {
    position: absolute;
    right: 0.5rem;
    top: 50%;
    transform: translateY(-50%);
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 0.15rem;
    color: #2563eb;
    transition: color 0.2s ease;
    }
    .input-with-icon button:hover, .input-with-icon button:focus {
    color: #1e40af;
    outline: none;
    }
    .input-with-icon button svg {
    width: 20px;
    height: 20px;
    stroke-width: 3;
    }

    button.see-prices {
    margin-top: 1rem;
    padding: 0.9rem;
    font-size: 1.125rem;
    border-radius: 1rem;
    font-weight: 700;
    transition: background-color 0.3s ease;
    border: none;
    width: 140px;
    }

    /* Right side image container */
    .illustration-container {
    flex: 1 1 500px;
    max-width: 600px;
    display: flex;
    justify-content: center;
    align-items: center;
    }
    .illustration-container img {
    width: 100%;
    height: auto;
    border-radius: 1.5rem;
    box-shadow: 0 8px 20px rgb(37 99 235 / 0.15);
      /* user-select: none; */
    }

    /* Footer */

    body {
    margin: 0;
    font-family: Arial, sans-serif;
}

.footer {
