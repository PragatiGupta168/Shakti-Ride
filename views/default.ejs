    display: flex;
    align-items: center;
    justify-content: center;
  }
  #scrollTopBtn:hover {
    background: linear-gradient(135deg, #4a0d6b, #f9e0e5);
    transform: scale(1.1);
  }
  #scrollTopBtn svg {
    pointer-events: none;
  }


